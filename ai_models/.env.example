# Open-Meteo API configuration (no API key required)
WEATHER_BASE_URL=https://api.open-meteo.com/v1/forecast

# Backend API for fetching pricing configuration
BACKEND_CONFIG_URL=http://localhost:8000/admin/pricing-config

# Configuration source: 'local' (JSON file) or 'backend' (API)
CONFIG_SOURCE=local

# Model and config paths
MODEL_PATH=ai_models/model/risk_model.pkl
PRICING_CONFIG_PATH=ai_models/config/pricing_config.json

# ML Service Configuration
ML_SERVICE_HOST=0.0.0.0
ML_SERVICE_PORT=8001
