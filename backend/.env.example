# Django
SECRET_KEY=<SecretKey>
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (option 1: individual fields)
DB_NAME=rakshak
DB_USER=postgres
DB_PASSWORD=<Password>
DB_HOST=localhost
DB_PORT=5432



# JWT
JWT_SECRET_KEY=change-this-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Services
ML_SERVICE_URL=http://localhost:8001
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
TIME_ZONE=Asia/Kolkata
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# External APIs
WEATHER_BASE_URL=https://api.open-meteo.com/v1/forecast
WAQI_BASE_URL=https://api.waqi.info/feed/geo
WAQI_API_TOKEN=
AQI_FALLBACK_SOURCE=openmeteo
NEWS_API_BASE_URL=https://newsapi.org/v2/everything
NEWS_API_KEY=
NEWS_QUERY=bandh OR strike OR curfew
EXTERNAL_REQUESTS_VERIFY_SSL=true

# Trigger thresholds
RAIN_TRIGGER_THRESHOLD=12.0
AQI_TRIGGER_THRESHOLD=300
NEWS_TRIGGER_THRESHOLD=0.75

# Claim caps
CLAIM_CAP_RAIN=600
CLAIM_CAP_AQI=500
CLAIM_CAP_NEWS=750
